# Local overrides for CRPTO. Copy to `.env.local` only if your shell/tooling
# loads it explicitly. Keep real values out of Git.

# Windows PowerShell users normally keep the project venv at `.venv/Scripts`.
# WSL users should avoid overwriting the Windows venv by setting:
#   export UV_PROJECT_ENVIRONMENT=.venv-wsl
UV_PROJECT_ENVIRONMENT=
UV_LINK_MODE=copy

# Optional local DVC remote name. Configure the real remote with:
#   uv run dvc remote add -d <name> <remote-url>
DVC_REMOTE_NAME=dagshub

# Optional GitHub target for first publication.
GITHUB_REPOSITORY_OWNER=EigenCharlie
GITHUB_REPOSITORY_NAME=Paper_CRPTO
