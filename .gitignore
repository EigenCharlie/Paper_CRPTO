# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
.venv-*/
.venv-broken-posix/

# Quarto
book/_book/
book/.quarto/
book/_freeze/
_book/
_freeze/
paper/*.html
paper/*.pdf
paper/*.tex
paper/*_files/

# Local runtime
.env
.env.*
!.env.example
!.env.local.example
.envrc
.direnv/
config.local
config.local.*
*.log
reports/run_logs/*/
!reports/run_logs/.gitkeep

# Original secret-bearing source files dropped by the user — never commit.
*_original
**/*_original
secrets.*
!secrets.example
**/.dvc_credentials*

# Data (DVC tracked — do not commit to git, use DVC remote)
data/raw/*
data/processed/*
data/processed/optuna/
# Allow .gitkeep markers if present
!data/raw/
!data/processed/
!data/processed/**/
!data/raw/.gitkeep
!data/processed/.gitkeep
# Allow DVC pointer files for GitHub/DVC reproducibility.
!data/raw/*.dvc
!data/processed/*.dvc
data/processed/**/*
!data/processed/**/*.dvc

# DVC cache, locks, tmp (only `.dvc/config` and `dvc.yaml`/`dvc.lock` belong in git)
.dvc/cache/
.dvc/tmp/
.dvc/lock
.dvc/config.local

# dbt compile output (regenerable)
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
dbt_project/.user.yml

# Models / heavy artefacts — keep them out of git (use DVC remote instead).
# Use ** patterns so subdirectories are caught.
**/*.cbm
**/*.pkl
**/*.onnx
**/*.skops
# Local search-run bundles (frozen candidate binaries, staging/backup copies)
# restored from the DVC remote or sibling checkouts; never versioned in git.
models/search_pd/
**/gpu_samples.csv
**/portfolio_*shortlist*.parquet
**/portfolio_*samples*.parquet
# Allow the small status JSONs and manifest at the models/ root.
!models/*_status.json
!models/final_project_promotion.json
!models/crpto_*.json
!models/champion_*.json
!models/conformal_method_registry.json
!models/conformal_gap_summary.json
models/conformal_gap/
models/feature_artifacts_last_valid_artifact.json
models/feature_artifacts_runtime_status.json

# Reports (large generated outputs)
reports/run_logs/
reports/notebook_images/
reports/paper_material/
reports/crpto/experiments/
reports/figures/**
!reports/figures/**/
!reports/figures/**/*.dvc
catboost_info/

# Local literature PDFs copied for reading only. Keep citations/DOIs in
# book/references.bib and docs; do not commit copyrighted PDFs.
Papers_tesis/

# Duckdb
*.duckdb
*.duckdb.wal

# Claude Code local-only settings
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/skills/local/
# Source diagram drop-off (vendored copy lives in book/assets/figures/editorial/)
diagrama.png

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# MLflow local
mlruns/
mlartifacts/

# Scratch runtime checkpoints are observability, not canonical deliverables.
models/*_runtime_checkpoints/

# Optuna local
optuna.db
optuna.db-journal

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# Hypothesis
.hypothesis/
.tmp_*/
# Ignore experiment outputs but keep the two promoted pool93 governance JSONs
# (protected body-claim sources per docs/SCOPE_AND_GOVERNANCE.md).
models/experiments/**
!models/experiments/**/
!models/experiments/champion_reopen/champion-reopen-2026-06-19__pool93__ijds-claim-bound-terminal/portfolio/pool93_ijds_claim_governance.json
!models/experiments/champion_reopen/champion-reopen-2026-06-19__pool93__ijds-claim-consolidated-definitive/portfolio/pool93_ijds_consolidated_governance.json
!models/experiments/champion_reopen/champion-reopen-2026-06-19__pool93__ijds-claim-consolidated-definitive/portfolio/pool93_ijds_consolidated_frontier.json
configs/experiments/
!configs/experiments/
configs/experiments/*
!configs/experiments/tabprep_*.yaml
!configs/experiments/tabpfn_*.yaml
!configs/experiments/champion_reopen*.yaml
!configs/experiments/champion_reopen*.txt
