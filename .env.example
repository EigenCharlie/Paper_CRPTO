# Copia este archivo a .env y rellena con tus tokens reales.
# .env esta en .gitignore. Nunca commitees secretos.

# DagsHub / MLflow para el repo standalone CRPTO.
DAGSHUB_OWNER=YOUR_GITHUB_OR_DAGSHUB_USER
DAGSHUB_USER=YOUR_GITHUB_OR_DAGSHUB_USER
DAGSHUB_REPO=Paper_CRPTO
DAGSHUB_TOKEN=
DAGSHUB_USER_TOKEN=

# MLflow tracking. Usa valores del repo Paper_CRPTO en DagsHub si lo activas.
MLFLOW_TRACKING_URI=https://dagshub.com/YOUR_GITHUB_OR_DAGSHUB_USER/Paper_CRPTO.mlflow
MLFLOW_TRACKING_USERNAME=YOUR_GITHUB_OR_DAGSHUB_USER
MLFLOW_TRACKING_PASSWORD=
MLFLOW_EXPERIMENT_NAME=crpto

# DVC remotes. No pongas credenciales en .dvc/config; usa variables/env local.
DVC_REMOTE_NAME=dagshub
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# DVC remote Google Drive alternativo.
GDRIVE_FOLDER_ID=

# GitHub CLI / automation local opcional. GitHub Actions usa GITHUB_TOKEN propio.
GH_TOKEN=
GITHUB_TOKEN=

# Paths runtime (override solo si tu venv vive en otra ubicación)
# QUARTO_PYTHON deliberadamente NO se setea aqui; uv run -- quarto lo resuelve.
CRPTO_DATA_DIR=data
CRPTO_MODELS_DIR=models
CRPTO_DUCKDB_PATH=data/processed/crpto.duckdb
CRPTO_PORTFOLIO_DIR=data/processed/portfolio_bound_aware/rank1_alpha01_bound_aware_276k_full_2026-04-05-1734
CRPTO_CONFORMAL_WINNER_DIR=data/processed/conformal_gap/conformal-reopen-2026-04-03-2149__resume__2026-04-05-1612__phase1__final__rank-1

# Optuna storage (opcional, para HPO con JournalStorage)
OPTUNA_STORAGE=
