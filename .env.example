# Copia este archivo a .env y rellena con tus tokens reales.
# .env está en .gitignore. NUNCA commitees secretos.

# ─── DagsHub identities ────────────────────────────────────────────────
# CRPTO is standalone: DVC artefacts and MLflow runs live in the dedicated
# DagsHub project `EigenCharlie94/Paper_CRPTO`, not in the parent project.
DAGSHUB_USER=EigenCharlie94
DAGSHUB_OWNER=EigenCharlie94
DAGSHUB_REPO=Paper_CRPTO
DAGSHUB_TOKEN=                 # 40-char token; same value used as USER_TOKEN
DAGSHUB_USER_TOKEN=            # canonical name for the dagshub client

# ─── MLflow (DagsHub-hosted) ───────────────────────────────────────────
MLFLOW_TRACKING_URI=https://dagshub.com/EigenCharlie94/Paper_CRPTO.mlflow
MLFLOW_TRACKING_USERNAME=EigenCharlie94
MLFLOW_TRACKING_PASSWORD=      # same as DAGSHUB_TOKEN
MLFLOW_EXPERIMENT_NAME=crpto

# ─── DVC remote (DagsHub S3-compatible endpoint) ───────────────────────
# The endpoint URL is committed to `.dvc/config`; credentials live in
# `.dvc/config.local` (gitignored) or in the AWS_* env vars below.
DVC_REMOTE_NAME=dagshub
AWS_ENDPOINT_URL=https://dagshub.com/EigenCharlie94/Paper_CRPTO.s3
AWS_ACCESS_KEY_ID=             # = DAGSHUB_TOKEN
AWS_SECRET_ACCESS_KEY=         # = DAGSHUB_TOKEN
AWS_DEFAULT_REGION=us-east-1

# ─── Optional local-only integrations ──────────────────────────────────
# These are not needed by the default workflows. Keep them empty unless a
# one-off local script explicitly asks for them.
GDRIVE_FOLDER_ID=
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_SERVICE_ACCOUNT_JSON=

# ─── GitHub CLI / automation (local only) ──────────────────────────────
# GitHub Actions uses its own GITHUB_TOKEN automatically; these are only
# for local scripts that need to talk to the GitHub API.
GH_TOKEN=
GITHUB_TOKEN=
GITHUB_PAT=

# ─── CRPTO runtime paths ───────────────────────────────────────────────
# QUARTO_PYTHON is intentionally NOT set here; `uv run -- quarto` resolves it.
CRPTO_DATA_DIR=data
CRPTO_MODELS_DIR=models
CRPTO_DUCKDB_PATH=data/processed/crpto.duckdb
CRPTO_PORTFOLIO_DIR=data/processed/portfolio_bound_aware/rank1_alpha01_bound_aware_276k_full_2026-04-05-1734
CRPTO_CONFORMAL_WINNER_DIR=data/processed/conformal_gap/conformal-reopen-2026-04-03-2149__resume__2026-04-05-1612__phase1__final__rank-1

# ─── Optuna storage ────────────────────────────────────────────────────
# Examples: journal:/tmp/study.log  |  sqlite:///optuna.db  |  empty (default journal)
OPTUNA_STORAGE=

GROK_API_KEY=
